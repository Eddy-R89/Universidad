void insertarCurso() {
    string n, c;
    cout << "Nombre: "; cin >> n;
    cout << "Codigo: "; cin >> c;

    string q = "INSERT INTO cursos(nombre,codigo) VALUES('" + n + "','" + c + "')";

    SQLHSTMT h;
    SQLAllocHandle(SQL_HANDLE_STMT, hDbc, &h);
    SQLExecDirect(h, (SQLCHAR*)q.c_str(), SQL_NTS);
    cout << "Curso agregado\n";
}
